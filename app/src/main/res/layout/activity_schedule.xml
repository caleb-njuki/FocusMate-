                    <EditText android:layout_width="0dp" android:layout_weight="1" android:hint="Empty" android:textColorHint="#555555" android:textColor="#FFFFFF" android:textSize="12sp" android:padding="6dp" android:gravity="center" android:backgroundTint="#4A148C" android:id="@+id/etThu3"/>
                    <EditText android:layout_width="0dp" android:layout_weight="1" android:hint="Empty" android:textColorHint="#555555" android:textColor="#FFFFFF" android:textSize="12sp" android:padding="6dp" android:gravity="center" android:backgroundTint="#4A148C" android:id="@+id/etThu4"/>
                    <EditText android:layout_width="0dp" android:layout_weight="1" android:hint="Empty" android:textColorHint="#555555" android:textColor="#FFFFFF" android:textSize="12sp" android:padding="6dp" android:gravity="center" android:backgroundTint="#4A148C" android:id="@+id/etThu5"/>
