                    <EditText android:layout_width="0dp" android:layout_weight="1" android:hint="Empty" android:textColorHint="#555555" android:textColor="#FFFFFF" android:textSize="12sp" android:padding="6dp" android:gravity="center" android:backgroundTint="#4A148C" android:id="@+id/etThu7"/>
                    <EditText android:layout_width="0dp" android:layout_weight="1" android:hint="Empty" android:textColorHint="#555555" android:textColor="#FFFFFF" android:textSize="12sp" android:padding="6dp" android:gravity="center" android:backgroundTint="#4A148C" android:id="@+id/etThu8"/>

                </TableRow>

                <TableRow android:padding="2dp">
                    <TextView android:text="Fri" android:textColor="#FFFFFF" android:textStyle="bold" android:padding="6dp" android:gravity="center"/>
                    <EditText android:layout_width="0dp" android:layout_weight="1" android:hint="Empty" android:textColorHint="#555555" android:textColor="#FFFFFF" android:textSize="12sp" android:padding="6dp" android:gravity="center" android:backgroundTint="#4A148C" android:id="@+id/etFri1"/>
                    <EditText android:layout_width="0dp" android:layout_weight="1" android:hint="Empty" android:textColorHint="#555555" android:textColor="#FFFFFF" android:textSize="12sp" android:padding="6dp" android:gravity="center" android:backgroundTint="#4A148C" android:id="@+id/etFri2"/>
                    <EditText android:layout_width="0dp" android:layout_weight="1" android:hint="Empty" android:textColorHint="#555555" android:textColor="#FFFFFF" android:textSize="12sp" android:padding="6dp" android:gravity="center" android:backgroundTint="#4A148C" android:id="@+id/etFri3"/>
                    <EditText android:layout_width="0dp" android:layout_weight="1" android:hint="Empty" android:textColorHint="#555555" android:textColor="#FFFFFF" android:textSize="12sp" android:padding="6dp" android:gravity="center" android:backgroundTint="#4A148C" android:id="@+id/etFri4"/>
                    <EditText android:layout_width="0dp" android:layout_weight="1" android:hint="Empty" android:textColorHint="#555555" android:textColor="#FFFFFF" android:textSize="12sp" android:padding="6dp" android:gravity="center" android:backgroundTint="#4A148C" android:id="@+id/etFri5"/>
                    <EditText android:layout_width="0dp" android:layout_weight="1" android:hint="Empty" android:textColorHint="#555555" android:textColor="#FFFFFF" android:textSize="12sp" android:padding="6dp" android:gravity="center" android:backgroundTint="#4A148C" android:id="@+id/etFri6"/>
                    <EditText android:layout_width="0dp" android:layout_weight="1" android:hint="Empty" android:textColorHint="#555555" android:textColor="#FFFFFF" android:textSize="12sp" android:padding="6dp" android:gravity="center" android:backgroundTint="#4A148C" android:id="@+id/etFri7"/>
                    <EditText android:layout_width="0dp" android:layout_weight="1" android:hint="Empty" android:textColorHint="#555555" android:textColor="#FFFFFF" android:textSize="12sp" android:padding="6dp" android:gravity="center" android:backgroundTint="#4A148C" android:id="@+id/etFri8"/>

                </TableRow>

                <TableRow android:padding="2dp">
                    <TextView android:text="Sat" android:textColor="#FFFFFF" android:textStyle="bold" android:padding="6dp" android:gravity="center"/>
                    <EditText android:layout_width="0dp" android:layout_weight="1" android:hint="Empty" android:textColorHint="#555555" android:textColor="#FFFFFF" android:textSize="12sp" android:padding="6dp" android:gravity="center" android:backgroundTint="#4A148C" android:id="@+id/etSat1"/>
                    <EditText android:layout_width="0dp" android:layout_weight="1" android:hint="Empty" android:textColorHint="#555555" android:textColor="#FFFFFF" android:textSize="12sp" android:padding="6dp" android:gravity="center" android:backgroundTint="#4A148C" android:id="@+id/etSat2"/>
                    <EditText android:layout_width="0dp" android:layout_weight="1" android:hint="Empty" android:textColorHint="#555555" android:textColor="#FFFFFF" android:textSize="12sp" android:padding="6dp" android:gravity="center" android:backgroundTint="#4A148C" android:id="@+id/etSat3"/>
                    <EditText android:layout_width="0dp" android:layout_weight="1" android:hint="Empty" android:textColorHint="#555555" android:textColor="#FFFFFF" android:textSize="12sp" android:padding="6dp" android:gravity="center" android:backgroundTint="#4A148C" android:id="@+id/etSat4"/>
                    <EditText android:layout_width="0dp" android:layout_weight="1" android:hint="Empty" android:textColorHint="#555555" android:textColor="#FFFFFF" android:textSize="12sp" android:padding="6dp" android:gravity="center" android:backgroundTint="#4A148C" android:id="@+id/etSat5"/>
                    <EditText android:layout_width="0dp" android:layout_weight="1" android:hint="Empty" android:textColorHint="#555555" android:textColor="#FFFFFF" android:textSize="12sp" android:padding="6dp" android:gravity="center" android:backgroundTint="#4A148C" android:id="@+id/etSat6"/>
                    <EditText android:layout_width="0dp" android:layout_weight="1" android:hint="Empty" android:textColorHint="#555555" android:textColor="#FFFFFF" android:textSize="12sp" android:padding="6dp" android:gravity="center" android:backgroundTint="#4A148C" android:id="@+id/etSat7"/>
                    <EditText android:layout_width="0dp" android:layout_weight="1" android:hint="Empty" android:textColorHint="#555555" android:textColor="#FFFFFF" android:textSize="12sp" android:padding="6dp" android:gravity="center" android:backgroundTint="#4A148C" android:id="@+id/etSat8"/>

                </TableRow>

                <TableRow android:padding="2dp">
                    <TextView android:text="Sun" android:textColor="#FFFFFF" android:textStyle="bold" android:padding="6dp" android:gravity="center"/>
                    <EditText android:layout_width="0dp" android:layout_weight="1" android:hint="Empty" android:textColorHint="#555555" android:textColor="#FFFFFF" android:textSize="12sp" android:padding="6dp" android:gravity="center" android:backgroundTint="#4A148C" android:id="@+id/etSun1"/>
                    <EditText android:layout_width="0dp" android:layout_weight="1" android:hint="Empty" android:textColorHint="#555555" android:textColor="#FFFFFF" android:textSize="12sp" android:padding="6dp" android:gravity="center" android:backgroundTint="#4A148C" android:id="@+id/etSun2"/>
